{
  "name": "quizzer",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:8082": "expo start --port 8082",
    "start:tunnel": "expo start --tunnel",
    "start:clean": "expo start -c",
    "start:clean:8082": "expo start -c --port 8082",
    "start:clean:lan": "expo start -c --lan",
    "start:clean:tunnel": "expo start --tunnel -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check-env": "node scripts/check-env.mjs",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "eas": "npx eas-cli",
    "build:internal": "npx eas-cli build --profile preview",
    "build:internal:ios": "npx eas-cli build --profile preview --platform ios",
    "build:internal:android": "npx eas-cli build --profile preview --platform android",
    "build:dev-client": "npx eas-cli build --profile development"
  },
  "dependencies": {
    "@expo-google-fonts/anton": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "dotenv": "^16.6.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
