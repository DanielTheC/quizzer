# Copy to .env and fill in your values. Use exact key names (case-sensitive).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional, local dev only (__DEV__): skip login and role-picker sees a fake user.
# Omit or set to 0 for EAS/production. Restart Expo after changing.
# EXPO_PUBLIC_DEV_SKIP_AUTH=1

# Optional: Android map tiles (react-native-maps / Google). iOS uses Apple Maps without this.
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
