{
  "expo": {
    "name": "quizzer",
    "slug": "quizzer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFD400"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Quizzer uses your location to show pub quizzes happening near you."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "quizzer-quiz-reminders"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Quizzer uses your location to show pub quizzes happening near you.",
        "NSUserNotificationsUsageDescription": "Quizzer sends a friendly reminder on the days your saved quizzes happen.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFD400"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "supabaseUrl": "https://xcmqvnddhcmombiqflny.supabase.co",
      "supabaseAnonKey": "sb_publishable_vDNt8LUH56HjUVYlJcRWrg_0SGoBPDp",
      "eas": {
        "projectId": "49b6e492-ce76-4ec5-8bfb-74158e9307d5"
      }
    }
  }
}
